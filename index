<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Aqua — Water Pollution & Its Consequences</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Outfit:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<style>
:root {
  --black:#060c0f;--dark:#0d1a20;--charcoal:#122030;--smoke:#1a2e3d;
  --ash:#2e4a5a;--stone:#4a7080;--sand:#b8d4dc;--parch:#e8f4f8;--white:#f4fafc;
  --amber:#00b4d8;--ember:#0077b6;--forest:#023e58;--moss:#0a6070;
  --fern:#1a8a9a;--mint:#48cae4;--ice:#90e0ef;--ocean:#023e8a;--wave:#0096c7;
  --danger:#e63946;--warn:#f4a261;--ok:#52b788;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Outfit',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;cursor:none}
img{display:block;max-width:100%}
a{text-decoration:none;color:inherit}

.cursor{position:fixed;width:10px;height:10px;background:var(--mint);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .3s,height .3s;mix-blend-mode:difference}
.cursor-ring{position:fixed;width:36px;height:36px;border:1px solid rgba(72,202,228,.5);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:left .06s,top .06s,width .3s,height .3s}
#progress{position:fixed;top:0;left:0;height:2px;width:0%;background:linear-gradient(90deg,var(--mint),var(--ember));z-index:1000}

nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:1.5rem 4rem;transition:background .4s,padding .4s}
nav.scrolled{background:rgba(6,12,15,.92);backdrop-filter:blur(16px);padding:1rem 4rem;border-bottom:1px solid rgba(72,202,228,.08)}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:.15em}
.nav-logo span{color:var(--mint)}
.nav-links{display:flex;gap:2.5rem;list-style:none;align-items:center}
.nav-links a{font-size:.78rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.6);transition:color .2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--mint);transition:width .3s}
.nav-links a:hover{color:var(--white)}
.nav-links a:hover::after{width:100%}
.nav-cta{background:var(--ember)!important;color:var(--white)!important;padding:.5rem 1.4rem;border-radius:2px;font-weight:600!important}
.nav-cta::after{display:none!important}
.nav-cta:hover{background:var(--wave)!important}

#hero{position:relative;width:100%;height:100vh;overflow:hidden;display:flex;align-items:flex-end}
.hero-bg{position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1621451537084-482c73073a0f?w=1800&q=90') center/cover no-repeat;animation:heroZoom 14s ease-in-out infinite alternate}
@keyframes heroZoom{from{transform:scale(1.05)}to{transform:scale(1.12)}}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(6,12,15,1) 0%,rgba(6,12,15,.6) 45%,rgba(6,12,15,.15) 100%)}
.hero-side{position:absolute;right:2.5rem;top:50%;transform:translateY(-50%) rotate(90deg);font-size:.68rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.25);white-space:nowrap}
.hero-content{position:relative;z-index:2;width:100%;padding:0 4rem 5rem}
.hero-eyebrow{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;opacity:0;animation:slideUp .8s .2s ease forwards}
.hero-eyebrow span{font-size:.72rem;font-weight:500;letter-spacing:.25em;text-transform:uppercase;color:var(--mint)}
.eyebrow-line{width:40px;height:1px;background:var(--mint)}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(4rem,10vw,9rem);font-weight:300;line-height:.92;letter-spacing:-.02em;opacity:0;animation:slideUp .9s .4s ease forwards}
.hero-title em{font-style:italic;color:var(--mint)}
.hero-title .outline{-webkit-text-stroke:1px rgba(255,255,255,.35);color:transparent}
.hero-bottom{display:flex;align-items:flex-end;justify-content:space-between;margin-top:2.5rem;opacity:0;animation:slideUp .9s .7s ease forwards}
.hero-desc{max-width:480px;font-size:1rem;line-height:1.8;color:rgba(255,255,255,.6);font-weight:300}
.hero-stats-row{display:flex;gap:2.5rem}
.h-stat .num{font-family:'Bebas Neue',sans-serif;font-size:2.8rem;color:var(--white);line-height:1;display:block;letter-spacing:.05em}
.h-stat .num span{color:var(--mint);font-size:1.8rem}
.h-stat .lbl{font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.2rem}
.scroll-hint{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.5rem;z-index:2;opacity:0;animation:fadeIn 1s 1.4s ease forwards}
.scroll-hint span{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.25)}
.scroll-arrow{width:20px;height:30px;border:1px solid rgba(255,255,255,.15);border-radius:10px;position:relative}
.scroll-arrow::after{content:'';position:absolute;top:5px;left:50%;transform:translateX(-50%);width:4px;height:4px;background:var(--mint);border-radius:50%;animation:bounce 1.5s ease infinite}
@keyframes bounce{0%,100%{top:5px;opacity:1}50%{top:16px;opacity:.3}}
@keyframes slideUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

.ticker{background:var(--ember);padding:.7rem 0;overflow:hidden;display:flex}
.ticker-track{display:flex;white-space:nowrap;animation:ticker 35s linear infinite}
.ticker-track span{font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:.2em;color:var(--white);padding:0 2rem}
.ticker-sep{color:rgba(255,255,255,.35)!important}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

.section-tag{display:inline-flex;align-items:center;gap:.6rem;font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;color:var(--mint);margin-bottom:1.2rem}
.section-tag::before{content:'';width:24px;height:1px;background:var(--mint)}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

#intro{display:grid;grid-template-columns:1fr 1fr;min-height:80vh}
.intro-visual{position:relative;overflow:hidden;min-height:400px}
.intro-visual img{width:100%;height:100%;object-fit:cover;filter:saturate(.7) brightness(.75);transition:transform .7s ease,filter .7s}
.intro-visual:hover img{transform:scale(1.04);filter:saturate(.9) brightness(.85)}
.intro-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(6,12,15,.45) 0%,transparent 60%)}
.intro-img-label{position:absolute;bottom:1.5rem;left:1.5rem;font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.4)}
.intro-text{padding:6rem 5rem;display:flex;flex-direction:column;justify-content:center;background:var(--dark)}
.intro-heading{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,3vw,2.8rem);font-weight:300;line-height:1.2;margin-bottom:1.8rem}
.intro-heading em{font-style:italic;color:var(--mint)}
.intro-body{font-size:.95rem;line-height:1.85;color:rgba(255,255,255,.55);font-weight:300;margin-bottom:1.2rem}
.quote-pull{border-left:2px solid var(--mint);padding:1.2rem 1.5rem;margin:2rem 0;background:rgba(0,180,216,.05)}
.quote-pull p{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-style:italic;line-height:1.65;color:rgba(255,255,255,.82)}
.quote-pull cite{display:block;margin-top:.6rem;font-family:'Outfit',sans-serif;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3);font-style:normal}

#causes{padding:8rem 4rem;background:var(--charcoal)}
.causes-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:4rem;gap:2rem}
.causes-heading{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4.5vw,3.8rem);font-weight:300;line-height:1.1}
.causes-heading em{font-style:italic;color:var(--mint)}
.causes-subtext{max-width:300px;font-size:.88rem;line-height:1.75;color:rgba(255,255,255,.4);text-align:right}
.causes-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.05)}
.cause-card{background:var(--charcoal);padding:2.5rem;position:relative;overflow:hidden;transition:background .3s}
.cause-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--mint),transparent);transform:scaleX(0);transform-origin:left;transition:transform .4s ease}
.cause-card:hover{background:rgba(0,180,216,.04)}
.cause-card:hover::before{transform:scaleX(1)}
.cause-img{width:100%;height:155px;object-fit:cover;border-radius:3px;margin-bottom:1.5rem;filter:saturate(.55) brightness(.7);transition:filter .4s}
.cause-card:hover .cause-img{filter:saturate(.85) brightness(.82)}
.cause-num{font-family:'Bebas Neue',sans-serif;font-size:3.2rem;color:rgba(0,180,216,.1);line-height:1;margin-bottom:.4rem;transition:color .3s}
.cause-card:hover .cause-num{color:rgba(0,180,216,.22)}
.cause-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:400;margin-bottom:.6rem}
.cause-text{font-size:.83rem;line-height:1.78;color:rgba(255,255,255,.48)}
.cause-badge{display:inline-block;margin-top:1rem;background:rgba(0,180,216,.1);border:1px solid rgba(0,180,216,.22);color:var(--mint);font-size:.66rem;letter-spacing:.1em;padding:.22rem .75rem;border-radius:20px}

#consequences{padding:8rem 0;background:var(--black)}
.cons-intro{padding:0 4rem 4rem}
.cons-intro h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4.5vw,3.8rem);font-weight:300;line-height:1.1;margin-top:.5rem}
.cons-intro h2 em{font-style:italic;color:var(--mint)}
.con-row{display:grid;grid-template-columns:1fr 1fr;min-height:440px;border-top:1px solid rgba(255,255,255,.05)}
.con-row:nth-child(even) .con-img{order:2}
.con-row:nth-child(even) .con-text{order:1}
.con-img{position:relative;overflow:hidden}
.con-img img{width:100%;height:100%;object-fit:cover;filter:saturate(.6) brightness(.72);transition:transform .8s ease,filter .8s}
.con-row:hover .con-img img{transform:scale(1.05);filter:saturate(.82) brightness(.82)}
.con-img-num{position:absolute;top:1.5rem;left:1.5rem;font-family:'Bebas Neue',sans-serif;font-size:5rem;line-height:1;color:rgba(255,255,255,.07);pointer-events:none}
.con-img-badge{position:absolute;bottom:1.5rem;left:1.5rem;background:rgba(0,119,182,.8);backdrop-filter:blur(8px);font-size:.66rem;letter-spacing:.15em;text-transform:uppercase;padding:.35rem .9rem;border-radius:2px}
.con-text{padding:4rem;display:flex;flex-direction:column;justify-content:center;background:var(--dark)}
.con-text h3{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,2.8vw,2.3rem);font-weight:400;line-height:1.2;margin-bottom:1.1rem}
.con-text h3 em{font-style:italic;color:var(--mint)}
.con-text p{font-size:.9rem;line-height:1.82;color:rgba(255,255,255,.52);margin-bottom:1rem}
.con-stat-box{display:flex;gap:2rem;margin-top:.5rem;flex-wrap:wrap}
.con-stat .n{font-family:'Bebas Neue',sans-serif;font-size:1.9rem;color:var(--mint);letter-spacing:.05em}
.con-stat .l{font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-top:.1rem}

/* ===== MAP SECTION ===== */
#river-map{padding:0;background:var(--black);border-top:1px solid rgba(255,255,255,.05)}
.map-header{padding:5rem 4rem 3rem}
.map-header h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4.5vw,3.8rem);font-weight:300;line-height:1.1;margin-top:.5rem}
.map-header h2 em{font-style:italic;color:var(--mint)}
.map-header p{font-size:.9rem;line-height:1.8;color:rgba(255,255,255,.45);max-width:640px;margin-top:.8rem}
.map-container{position:relative;height:620px;background:var(--dark)}
#leaflet-map{width:100%;height:100%}
.map-controls{position:absolute;top:1.2rem;left:50%;transform:translateX(-50%);z-index:800;display:flex;gap:.5rem;background:rgba(6,12,15,.88);backdrop-filter:blur(12px);border:1px solid rgba(72,202,228,.12);border-radius:4px;padding:.4rem}
.map-btn{font-family:'Outfit',sans-serif;font-size:.72rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;padding:.45rem 1.1rem;border-radius:3px;border:none;cursor:pointer;transition:background .2s,color .2s;background:transparent;color:rgba(255,255,255,.5)}
.map-btn.active{background:var(--ember);color:var(--white)}
.map-btn:hover:not(.active){background:rgba(255,255,255,.07);color:var(--white)}
.map-legend{position:absolute;bottom:1.5rem;right:1.5rem;z-index:800;background:rgba(6,12,15,.88);backdrop-filter:blur(12px);border:1px solid rgba(72,202,228,.12);border-radius:4px;padding:1rem 1.2rem;min-width:170px}
.map-legend h5{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.8rem}
.legend-item{display:flex;align-items:center;gap:.6rem;margin-bottom:.5rem;font-size:.78rem;color:rgba(255,255,255,.6)}
.legend-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0}
.map-info-panel{padding:2rem 4rem 3rem;background:var(--dark);display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem}
.map-info-card{border:1px solid rgba(255,255,255,.06);border-radius:3px;padding:1.4rem;background:rgba(255,255,255,.02)}
.mic-label{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:.4rem}
.mic-val{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:.05em;color:var(--mint)}
.mic-sub{font-size:.78rem;color:rgba(255,255,255,.4);margin-top:.3rem;line-height:1.55}

#scenarios{padding:8rem 4rem;background:linear-gradient(180deg,var(--forest) 0%,var(--black) 100%);position:relative;overflow:hidden}
#scenarios::before{content:'';position:absolute;top:-200px;right:-200px;width:500px;height:500px;background:radial-gradient(circle,rgba(0,150,199,.18) 0%,transparent 70%);pointer-events:none}
.scenarios-header{text-align:center;margin-bottom:5rem}
.scenarios-header h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4.5vw,3.8rem);font-weight:300;margin-top:.5rem}
.scenarios-header h2 em{font-style:italic;color:var(--mint)}
.scenarios-header p{font-size:.9rem;color:rgba(255,255,255,.42);max-width:520px;margin:.8rem auto 0;line-height:1.75}
.scenarios-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem}
.sc-card{border-radius:4px;overflow:hidden;transition:transform .4s ease}
.sc-card:hover{transform:translateY(-8px)}
.sc-img{height:290px;position:relative;overflow:hidden}
.sc-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
.sc-card:hover .sc-img img{transform:scale(1.08)}
.sc-overlay{position:absolute;inset:0}
.sc-card:nth-child(1) .sc-overlay{background:linear-gradient(to top,rgba(2,62,88,.92) 0%,rgba(2,62,88,.15) 60%)}
.sc-card:nth-child(2) .sc-overlay{background:linear-gradient(to top,rgba(10,96,112,.92) 0%,rgba(10,96,112,.15) 60%)}
.sc-card:nth-child(3) .sc-overlay{background:linear-gradient(to top,rgba(180,80,0,.92) 0%,rgba(180,80,0,.15) 60%)}
.sc-card:nth-child(4) .sc-overlay{background:linear-gradient(to top,rgba(150,20,20,.92) 0%,rgba(150,20,20,.15) 60%)}
.sc-wqi{position:absolute;top:1.2rem;left:1.5rem;font-family:'Bebas Neue',sans-serif;font-size:3.5rem;line-height:1;color:rgba(255,255,255,.88)}
.sc-body{padding:1.8rem;background:var(--charcoal)}
.sc-label{font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;margin-bottom:.5rem;display:block}
.sc-card:nth-child(1) .sc-label{color:#52b788}
.sc-card:nth-child(2) .sc-label{color:var(--mint)}
.sc-card:nth-child(3) .sc-label{color:var(--warn)}
.sc-card:nth-child(4) .sc-label{color:var(--danger)}
.sc-title{font-family:'Cormorant Garamond',serif;font-size:1.15rem;margin-bottom:.9rem}
.sc-list{list-style:none;display:flex;flex-direction:column;gap:.45rem}
.sc-list li{font-size:.8rem;line-height:1.55;color:rgba(255,255,255,.48);padding-left:1rem;position:relative}
.sc-list li::before{content:'→';position:absolute;left:0;color:rgba(255,255,255,.18)}

#impact{padding:8rem 4rem;background:var(--dark)}
.impact-layout{display:grid;grid-template-columns:1fr 1.5fr;gap:6rem;align-items:center}
.impact-left h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:300;line-height:1.2;margin-top:.5rem;margin-bottom:1.5rem}
.impact-left h2 em{font-style:italic;color:var(--mint)}
.impact-left p{font-size:.9rem;line-height:1.82;color:rgba(255,255,255,.48);margin-bottom:2rem}
.impact-num-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-top:1.5rem}
.impact-num{padding:1.4rem;border:1px solid rgba(255,255,255,.07);border-radius:3px}
.impact-num .n{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;color:var(--mint);letter-spacing:.05em}
.impact-num .l{font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-top:.2rem}
.bars{display:flex;flex-direction:column;gap:1.4rem}
.bar-meta{display:flex;justify-content:space-between;margin-bottom:.45rem}
.bar-name{font-size:.85rem;color:rgba(255,255,255,.65)}
.bar-val{font-family:'Bebas Neue',sans-serif;font-size:.9rem;color:var(--mint);letter-spacing:.08em}
.bar-track{height:6px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden}
.bar-fill{height:100%;border-radius:3px;width:0;transition:width 1.4s cubic-bezier(.4,0,.2,1)}
.bar-fill.blue{background:linear-gradient(90deg,var(--ember),var(--mint))}
.bar-fill.warn{background:linear-gradient(90deg,var(--warn),#f7c59f)}
.bar-fill.red{background:linear-gradient(90deg,var(--danger),#ff6b6b)}

#india-focus{background:var(--black)}
.india-title-block{padding:6rem 4rem 4rem}
.india-title-block h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4.5vw,3.8rem);font-weight:300;line-height:1.1;margin-top:.5rem}
.india-title-block h2 em{font-style:italic;color:var(--mint)}
.regions-mosaic{display:grid;grid-template-columns:1.5fr 1fr 1fr;grid-template-rows:300px 300px;gap:2px}
.region-card{position:relative;overflow:hidden}
.region-card.tall{grid-row:span 2}
.region-card img{width:100%;height:100%;object-fit:cover;filter:saturate(.45) brightness(.6);transition:transform .7s,filter .7s}
.region-card:hover img{transform:scale(1.07);filter:saturate(.75) brightness(.75)}
.region-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.88) 0%,transparent 55%)}
.region-content{position:absolute;bottom:1.8rem;left:1.8rem;right:1.8rem}
.region-badge{display:inline-block;margin-bottom:.6rem;font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;padding:.22rem .65rem;border-radius:20px;border:1px solid}
.region-card:nth-child(1) .region-badge{color:var(--danger);border-color:rgba(230,57,70,.35)}
.region-card:nth-child(2) .region-badge{color:var(--warn);border-color:rgba(244,162,97,.35)}
.region-card:nth-child(3) .region-badge{color:var(--mint);border-color:rgba(72,202,228,.35)}
.region-card:nth-child(4) .region-badge{color:#52b788;border-color:rgba(82,183,136,.35)}
.region-content h3{font-family:'Cormorant Garamond',serif;font-size:1.45rem;font-weight:400;margin-bottom:.35rem}
.region-content p{font-size:.8rem;line-height:1.62;color:rgba(255,255,255,.52)}

#timeline{padding:8rem 4rem;background:var(--charcoal)}
#timeline h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,4.5vw,3.8rem);font-weight:300;line-height:1.1;margin-top:.5rem;margin-bottom:4rem}
#timeline h2 em{font-style:italic;color:var(--mint)}
.timeline{position:relative;max-width:860px}
