function popup(data) {
  return `<div style="min-width:200px;padding:4px 2px">
    <div class="popup-title">${data.name}</div>
    <div class="popup-location">${data.loc}</div>
    <div style="font-size:.78rem;color:rgba(255,255,255,.55);line-height:1.55;margin-bottom:.5rem">${data.desc}</div>
    <div class="popup-row">
      <div class="popup-stat"><div class="pv" style="color:${data.color}">${data.wqi}</div><div class="pl">WQI Score</div></div>
      <div class="popup-stat"><div class="pv" style="color:#90e0ef">${data.pop}</div><div class="pl">Pop. Affected</div></div>
    </div>
    <div style="margin-top:.6rem;font-size:.74rem;color:rgba(255,255,255,.45)"><strong style="color:rgba(255,255,255,.65)">Primary threat:</strong> ${data.threat}</div>
    <span class="popup-status ${statusClass[data.status]}">${data.status}</span>
  </div>`;
}

