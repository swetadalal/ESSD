let currentMarkers = [];

function clearMarkers() {
  currentMarkers.forEach(m => m.remove());
  currentMarkers = [];
}

function addMarkers(data) {
  data.forEach(d => {
    const marker = L.marker([d.lat, d.lng], { icon: makeIcon(d.color) })
      .addTo(map)
      .bindPopup(popup(d), { className: 'river-popup', maxWidth: 280 });
    currentMarkers.push(marker);
  });
}

function showView(view) {
  document.querySelectorAll('.map-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  clearMarkers();
  if (view === 'india') {
    map.flyTo([22.5, 82], 5, { duration: 1.2 });
    addMarkers(indiaRivers);
  } else {
    map.flyTo([20, 20], 2, { duration: 1.2 });
    addMarkers([...globalRivers, ...indiaRivers]);
  }
}

